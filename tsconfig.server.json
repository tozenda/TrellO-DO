{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist-server",
    "rootDir": ".",
    "noEmit": false,
    "types": ["node", "vitest/globals"],
    "lib": ["ES2022", "DOM"]
  },
  "include": ["server/**/*.ts", "src/shared/**/*.ts"],
  "exclude": ["**/*.test.ts", "**/*.test.tsx"]
}
